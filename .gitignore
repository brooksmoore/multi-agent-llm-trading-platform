# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
*.egg-info/
dist/
build/

# Environment
.env
.env.local

# Data files (never commit market data; DO track data/*.py source)
data/*.db
data/*.duckdb
data/*.parquet
data/*.json
data/.cache/
*.db
*.db-shm
*.db-wal
*.db.bak
*.bak
# Timestamped/suffixed manual backups (e.g. lots.db.bak-pre-flatten-2026...).
# The bare *.bak glob above does not match anything after the ".bak".
*.bak-*
*.db.bak-*
.fuse_hidden*
*.duckdb
*.parquet

# Logs (do commit build_journal.md; gitignore ephemeral agent memos)
logs/*.json
logs/agent_memos/
logs/*.log
logs/*.log.[0-9]*
logs/*.jsonl

# Claude Code session state
.claude/

# macOS
.DS_Store

# IDE
.idea/
.vscode/

# Test / coverage artifacts
.pytest_cache/
.mypy_cache/
htmlcov/
.coverage
