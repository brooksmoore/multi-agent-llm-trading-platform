# ─── Alpaca (paper) ────────────────────────────────────────────────────────────
ALPACA_API_KEY=your_paper_key_here
ALPACA_SECRET_KEY=your_paper_secret_here
ALPACA_PAPER=true

# ─── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here

# ─── Finnhub (free tier) ───────────────────────────────────────────────────────
FINNHUB_API_KEY=your_finnhub_free_key_here

# ─── AlertAlerting via ntfy.sh ─────────────────────────────────────────────────
NTFY_TOPIC=your_ntfy_topic_here

# ─── Telegram (v1.5 — stub only in v1) ────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Risk / leverage overrides ─────────────────────────────────────────────────
# Set to 1.0 by default; range [0.0, 1.5]; above 1.5 requires OVERRIDE_KEY
MASTER_CAPABILITY=1.0
OVERRIDE_KEY=

# ─── Behaviour flags ───────────────────────────────────────────────────────────
AUTO_APPROVE=true
LOG_LEVEL=INFO

# ─── Budget ────────────────────────────────────────────────────────────────────
DAILY_SPEND_CAP=0.95

# ─── Storage paths ─────────────────────────────────────────────────────────────
DATA_DIR=data
LOGS_DIR=logs

# ─── Broker selection (default: alpaca paper) ──────────────────────────────────
# broker_kind: "alpaca" (paper, default) or "robinhood" (real-money MCP).
# Robinhood adapter defaults to DRY-RUN (robinhood_live_enabled=false).
# Only set live_enabled=true after schema verification + tiny test.
BROKER_KIND=alpaca

# ─── Robinhood agentic MCP (REAL MONEY — arm only after verification) ──────────
ROBINHOOD_MCP_URL=https://agent.robinhood.com/mcp/trading
ROBINHOOD_AUTH_TOKEN=
ROBINHOOD_LIVE_ENABLED=false

# ─── Reconciler (broker-aware) ─────────────────────────────────────────────────
# Alpaca has WS stream → 60s safety-net poll is fine.
# Robinhood has no stream → every fill waits on poll. 20s default for RH.
RECONCILER_INTERVAL_SECS=60
RECONCILER_INTERVAL_ROBINHOOD_SECS=20
RECONCILER_QTY_TOLERANCE=1
